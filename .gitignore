# Generated by Cargo
# will have compiled files and executables
/target/
**/target/

# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# Build / check / run logs — 全部丢 log/ 下，别再污染根目录
*.log
/log/
loop_run.out.txt
build_all.txt
build_core.txt
test_core.txt
test_log.txt
test_ws.txt
tmp_test.txt
# server boot / e2e test logs (server_test.* / server_e2e.* / server_run.* / server_dbg.* / server_dbg2.* / server_e2e3-5.*)
server_test.*
server_e2e.*
server_e2e[3-9].*
server_run.*
server_dbg.*
server_dbg2.*
# client boot / e2e test logs
client_e2e.*
client_e2e[3-9].*
client_dbg.*
client_dbg2.*

# Temporary / duplicate files
README copy.md

# IDE configurations
.idea/
.vscode/

# AI agent / planning tools
.mavis/
.harness/

# Temporary build artifacts
.opencode/

# Screenshots (generated during closed-loop iteration)
screenshots/
!screenshots/_archive/

